# Flask
FLASK_ENV=development
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too
JWT_ACCESS_TOKEN_EXPIRES_HOURS=72

# PostgreSQL
DATABASE_URL=postgresql+psycopg://parkreserve:parkreserve@localhost:5432/parkreserve

# Server
PORT=8000
# Vite dev server runs on :5173; add other origins (LAN IP, staging) as needed.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# MQTT (HiveMQ Cloud in production; local Mosquitto in dev)
MQTT_ENABLED=true
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TLS=false
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=parkreserve-backend
MQTT_TOPIC_PREFIX=cloud

# Reservation rules
# How far in advance a user can reserve a bay.
BOOKING_WINDOW_MINUTES=60

# Grace period before an unmatched arrival is treated as a no-show.
ARRIVAL_GRACE_MINUTES=1

# How long a bay can stay in pending check-in before the grace expires.
CHECK_IN_GRACE_MINUTES=1

# Cancelling within this many minutes of arrival counts as a late cancel.
LATE_CANCEL_CUTOFF_MINUTES=15

# Maximum number of licence plates one user account can bind.
PLATES_PER_USER_MAX=5

# Reserved confidence threshold for accepting licence plate recognition matches.
LPR_CONFIDENCE_THRESHOLD=0.80

# Mock-payment defaults
DEPOSIT_CENTS=1000
PENALTY_CENTS=500

# Conflict evidence retention
EVIDENCE_RETENTION_DAYS=30
EVIDENCE_STORAGE_PATH=/var/lib/parkreserve/evidence
EVIDENCE_UPLOAD_TOKEN=parkreserve-evidence-token

# Background jobs
# How often the safety-net sweeper runs to synthesise missed no_show / conflict_weak events.
RECONCILE_INTERVAL_SECONDS=30

# How often to purge expired strong-conflict evidence images from storage.
PURGE_INTERVAL_HOURS=24
