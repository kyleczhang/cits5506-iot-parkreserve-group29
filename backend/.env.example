# Flask
FLASK_ENV=development
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# PostgreSQL (production and tests both use PostgreSQL)
DATABASE_URL=postgresql+psycopg://parkreserve:parkreserve@localhost:5432/parkreserve

# MQTT (HiveMQ Cloud in production; local Mosquitto in dev)
MQTT_ENABLED=true
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TLS=false
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=parkreserve-backend
MQTT_TOPIC_PREFIX=cloud

# Reservation rules
RESERVATION_DEFAULT_MINUTES=15
RESERVATION_EXPIRY_GRACE_SECONDS=60

# Server
PORT=5000
CORS_ORIGINS=http://localhost:3000
